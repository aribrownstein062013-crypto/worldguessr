{
  "version": 2,
  "functions": {
    "api/ai-hint.js": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https: wss:;" }
      ]
    }
  ]
}
